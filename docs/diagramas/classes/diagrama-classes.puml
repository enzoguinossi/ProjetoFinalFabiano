@startuml Restaurante

'===============================================================
'                          ENUMERADORES
'===============================================================
enum StatusPedido {
    PENDENTE
    ATENDIDO
    CANCELADO
}

enum StatusMesa {
    LIVRE
    OCUPADA
}

enum TurnosTrabalho {
    MANHÃ
    TARDE
    NOITE
}

enum TiposPrato {
    ENTRADA
    PRATOPRINCIPAL
    BEBIDA
    SOBREMESA
}

'===============================================================
'                          CLASSES INTERFACE
'===============================================================


class FormularioBase {
    - pnlConteudo: JPanel
    - pnlBotoes: JPanel
    - btnSalvar: JButton
    - btnAlterar: JButton
    - btnExcluir: JButton
    - btnListar: JButton
    - btnFechar: JButton
}

